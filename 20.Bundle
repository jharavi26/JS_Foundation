## ­¤¤ó DESIGN PATTERNS

### 27. Common Design Patterns
- [ ] Module Pattern
- [ ] Singleton Pattern
- [ ] Factory Pattern
- [ ] Observer Pattern
- [ ] Strategy Pattern
- [ ] Decorator Pattern
- [ ] Command Pattern

**Key Concept**:
```javascript
// Module Pattern (Closures)
const counter = (() => {
  let count = 0;
  
  return {
    increment() { return ++count; },
    decrement() { return --count; },
    getCount() { return count; }
  };
})();

counter.increment(); // 1
counter.increment(); // 2
console.log(counter.getCount()); // 2

// Singleton Pattern
const singleton = (() => {
  let instance;
  
  function create() {
    return {
      id: Math.random()
    };
  }
  
  return {
    getInstance() {
      if (!instance) {
        instance = create();
      }
      return instance;
    }
  };
})();

console.log(singleton.getInstance() === singleton.getInstance()); // true

// Factory Pattern
function createUser(name, role) {
  return {
    name,
    role,
    greet() {
      return `Hi, I'm ${this.name}`;
    }
  };
}

const admin = createUser('John', 'admin');
const user = createUser('Jane', 'user');

// Observer Pattern
class EventEmitter {
  constructor() {
    this.listeners = {};
  }
  
  on(event, callback) {
    if (!this.listeners[event]) {
      this.listeners[event] = [];
    }
    this.listeners[event].push(callback);
  }
  
  emit(event, data) {
    if (this.listeners[event]) {
      this.listeners[event].forEach((callback) => callback(data));
    }
  }
}

const emitter = new EventEmitter();
emitter.on('message', (data) => console.log('Received:', data));
emitter.emit('message', 'Hello!');
```

**Master When**: You recognize patterns in code and apply them appropriately

