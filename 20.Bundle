**Key Concept**:
```javascript
// Keyboard events
document.addEventListener('keydown', (e) => {
  console.log(e.key);      // Character pressed
  console.log(e.code);     // Physical key code
  console.log(e.ctrlKey);  // Ctrl pressed?
});

// Form events
const input = document.querySelector('input');
input.addEventListener('input', (e) => {
  console.log(e.target.value); // Updated value
});

const form = document.querySelector('form');
form.addEventListener('submit', (e) => {
  e.preventDefault(); // Don't submit
  console.log('Form submitted');
});

// Window events
window.addEventListener('scroll', () => {
  console.log(window.scrollY); // Scroll position
});

window.addEventListener('resize', () => {
  console.log(window.innerWidth); // New width
});

// Touch events (mobile)
element.addEventListener('touchstart', (e) => {
  const touch = e.touches[0];
  console.log(touch.clientX, touch.clientY);
});
```

